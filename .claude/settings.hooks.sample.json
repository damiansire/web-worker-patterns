{
  "//": "MUESTRA — hooks event-driven (patrón ECC). NO se carga solo. Para activarlos,",
  "//install": "copiá el bloque \"hooks\" a .claude/settings.json (merge si ya existe).",
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/hooks/guard-regla-de-oro.mjs\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/hooks/cleanup-scratch.mjs\""
          }
        ]
      }
    ]
  }
}
